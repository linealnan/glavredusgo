{
    "swagger": "2.0",
    "info": {
        "title": "Glavredusgo API",
        "description": "API для поиска постов в группах ВКонтакте",
        "version": "1.0",
        "contact": {}
    },
    "host": "localhost:8080",
    "basePath": "/",
    "schemes": ["http", "https"],
    "paths": {
        "/api/search": {
            "post": {
                "description": "Выполняет поиск по индексированным постам ВКонтакте",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "search"
                ],
                "summary": "Поиск постов",
                "parameters": [
                    {
                        "description": "Запрос поиска",
                        "name": "searchRequest",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/application.SearchRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/application.SearchResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/application.SearchResponse"
                        }
                    },
                    "405": {
                        "description": "Method Not Allowed",
                        "schema": {
                            "$ref": "#/definitions/application.SearchResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "application.SearchRequest": {
            "type": "object",
            "properties": {
                "query": {
                    "type": "string"
                }
            }
        },
        "application.SearchResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string"
                },
                "results": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/application.SearchResult"
                    }
                },
                "total": {
                    "type": "integer"
                }
            }
        },
        "application.SearchResult": {
            "type": "object",
            "properties": {
                "group_id": {
                    "type": "string"
                },
                "group_name": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "text": {
                    "type": "string"
                },
                "url": {
                    "type": "string"
                }
            }
        }
    }
}